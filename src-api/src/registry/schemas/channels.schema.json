{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skilldock.local/schemas/registry/channels.schema.json",
  "title": "Skill Channels",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "skill_id",
    "channels",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "skill_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "channels": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable"
      ],
      "properties": {
        "beta": {
          "type": "string"
        },
        "stable": {
          "type": "string"
        }
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_by": {
      "type": "string"
    }
  }
}
