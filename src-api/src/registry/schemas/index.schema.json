{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skilldock.local/schemas/registry/index.schema.json",
  "title": "Skill Registry Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "skills"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Registry index schema version",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "skill_id",
          "publisher",
          "name",
          "source",
          "channels",
          "updated_at"
        ],
        "properties": {
          "skill_id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "publisher": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "repo",
              "ref"
            ],
            "properties": {
              "repo": {
                "type": "string",
                "format": "uri"
              },
              "ref": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string"
              }
            }
          },
          "channels": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "beta": {
                "type": "string"
              },
              "stable": {
                "type": "string"
              }
            }
          },
          "platforms": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "macos",
                "windows",
                "linux"
              ]
            },
            "uniqueItems": true
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
