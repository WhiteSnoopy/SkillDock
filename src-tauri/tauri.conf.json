{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkillDock",
  "version": "0.1.0",
  "identifier": "com.skilldock.skillagent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
